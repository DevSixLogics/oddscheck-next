# Copy to .env.local and adjust as needed.

# Base URL for the cms-oddscheck CMS API (football/new-matches, articles, etc.)
NEXT_PUBLIC_API_BASE=https://cms-oddscheck.hneeds.com/api/v1

# Seconds to cache feed fetches before revalidating.
NEXT_PUBLIC_API_REVALIDATE=60

# Origin for team/competitor logos (the iPublisher image service on the STORAGE
# host, no `cms-` prefix), e.g.
#   {IMAGE_BASE}/v1/sports/{sport}/competitor-logos/{id}.png?initials=XX&bg=ffffff&fg=000000
# If unset, it's derived from NEXT_PUBLIC_API_BASE by dropping the `cms-` prefix.
# (League flags are served locally from public/ip/assets/images/flags/.)
NEXT_PUBLIC_IMAGE_BASE=https://oddscheck.hneeds.com

# Live-match WebSocket (Laravel Echo + socket.io v2). Trailing slash.
NEXT_PUBLIC_SOCKETURL=https://socket.ipublisher.app/
